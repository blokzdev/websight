*.bak
*.orig

# Generated Firebase config (do not commit production values; ship google-services.json.example only)
# Note: a placeholder google-services.json is committed to keep `flutter build` working out of the box.
# After running `flutterfire configure` your real google-services.json overwrites it locally.
