<?xml version="1.0" encoding="utf-8"?>
<!--
  Tightened FileProvider paths. Only expose the app's external Downloads directory
  and the app-private cache; never the entire external storage root.
-->
<paths>
    <external-files-path name="downloads" path="Download/" />
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
</paths>
